[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[dn]
C=US
ST=State
L=City
O=VibePlant
OU=Platform
emailAddress=admin@planthub.local
CN=*.deloro3dpc.tech

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = *.deloro3dpc.tech
DNS.2 = deloro3dpc.tech
DNS.3 = localhost
IP.1 = 127.0.0.1
