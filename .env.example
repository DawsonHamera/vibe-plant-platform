# Backend bind host inside container/server process.
HOST=0.0.0.0

# Backend HTTP listen port.
PORT=3000

# Allowed origins for REST and WebSocket CORS, comma-separated.
CORS_ORIGINS=http://localhost:5173

# SQLite database path (absolute or relative to backend working directory).
SQLITE_DB_FILE=data/vibe-plant.sqlite

# Upload directory path (absolute or relative to backend working directory).
UPLOADS_DIR=data/uploads

# Frontend API base URL used at build time by Vite.
VITE_API_BASE_URL=http://localhost:3000

# Host port mapping for frontend container.
FRONTEND_PORT=8080
