# Raspberry Pi production-ish defaults
# Copy this to .env on the Pi and edit values.

HOST=0.0.0.0
PORT=43000
FRONTEND_PORT=48080

# Keep same-origin API path for frontend build/proxy.
VITE_API_BASE_URL=/api

# Add your public Cloudflare hostname and any local origins you use.
CORS_ORIGINS=http://localhost:48080,https://localhost:48080,http://127.0.0.1:48080,https://127.0.0.1:48080,https://plants.example.com

# Backend data paths (relative to apps/backend working directory).
SQLITE_DB_FILE=data/vibe-plant.sqlite
UPLOADS_DIR=data/uploads

# REQUIRED: set strong secrets before exposing publicly.
VIBE_AUTH_PASSPHRASE=replace-with-a-long-random-passphrase
VIBE_AUTH_SECRET=replace-with-a-long-random-signing-secret

# Optional: pin discoverable serial ports if auto-discovery is restricted by permissions.
# Example: VIBE_SERIAL_PORTS=/dev/ttyUSB0,/dev/ttyACM0
# VIBE_SERIAL_PORTS=

# Set true when serving through HTTPS (Cloudflare public hostname).
VIBE_AUTH_COOKIE_SECURE=true
