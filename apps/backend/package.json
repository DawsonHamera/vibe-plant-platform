{
  "name": "@vibe/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node --watch -r ts-node/register src/main.ts",
    "migrate": "tsx src/scripts/run-migrations.ts",
    "mock:telemetry": "tsx src/scripts/mock-telemetry-feed.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.3",
    "@nestjs/core": "^11.0.3",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/platform-express": "^11.0.3",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.0.3",
    "@vibe/shared": "0.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
